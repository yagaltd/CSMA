{
  "templateId": "csma-capacitor-shell",
  "engine": "csma",
  "runtime": "mobile-webview",
  "version": "1.0.0",
  "schemaVersion": "1.0.0",
  "description": "CSMA web template with Capacitor shell scaffolding and build sync script.",
  "requiredFiles": [
    "index.html",
    "package.json",
    "platforms/mobile-capacitor/capacitor.config.json",
    "scripts/build-mobile-capacitor.js"
  ],
  "sourcePaths": [
    "index.html",
    "package.json",
    "package-lock.json",
    "vite.config.js",
    "src",
    "public",
    "scripts/build-mobile-capacitor.js",
    "platforms/mobile-capacitor",
    "docs/platforms/capacitor.md"
  ],
  "compat": {
    "recommendedCli": ">=0.1.0"
  },
  "postScaffoldHints": [
    "npm install",
    "npm run build:mobile:capacitor",
    "cd platforms/mobile-capacitor && npx cap open android"
  ]
}
