# CSMA Kit - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# =============================================================================
# API Configuration
# =============================================================================

# Your backend API URL (if using a backend)
# Development: http://localhost:3001
# Production: https://api.yourdomain.com
VITE_API_URL=

# =============================================================================
# LLM Integration (Optional)
# =============================================================================

# OpenAI API Key (for LLM features)
# Get your key from: https://platform.openai.com/api-keys
# WARNING: Never commit this key! Keep it in .env (gitignored)
VITE_OPENAI_API_KEY=

# Alternative LLM Providers (uncomment if using)
# VITE_ANTHROPIC_API_KEY=
# VITE_GROQ_API_KEY=
# VITE_TOGETHER_API_KEY=

# =============================================================================
# Environment
# =============================================================================

# Current environment (development, staging, production)
VITE_ENV=development

# =============================================================================
# Feature Flags (Optional)
# =============================================================================

# Enable/disable features via environment
# VITE_ENABLE_PWA=true
# VITE_ENABLE_ANALYTICS=true
# VITE_ENABLE_LLM=false

# =============================================================================
# Analytics (Optional)
# =============================================================================

# Google Analytics ID (if using)
# VITE_GA_ID=

# Custom analytics endpoint
# VITE_ANALYTICS_URL=

# =============================================================================
# Security (Production)
# =============================================================================

# Allowed API domains for CSP (comma-separated)
# VITE_CSP_CONNECT_SRC=https://api.openai.com,https://api.yourdomain.com

# =============================================================================
# Notes
# =============================================================================
# 
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual values in .env
# 3. .env is gitignored - safe to store secrets locally
# 4. For production, use your hosting provider's environment variables
#    (Vercel, Netlify, etc. have built-in env var management)
# 5. All VITE_* variables are exposed to the client bundle
#    - Never put sensitive backend secrets here
#    - API keys here are client-visible (use backend proxy for sensitive operations)
